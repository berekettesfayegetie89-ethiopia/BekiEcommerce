# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:bekiman9522@localhost:5432/bekishop

# ── App ───────────────────────────────────────────────────────────────────────
JWT_SECRET=bekishop_super_secret_key_change_in_production
PORT=5000
SERVER_URL=http://localhost:5000        # public URL (for Chapa callbacks)
CLIENT_URL=http://localhost:5173

NODE_ENV=development

# ── Chapa (Ethiopian Payments) ────────────────────────────────────────────────
# Get keys at: https://dashboard.chapa.co → Settings → API Keys
# Test key starts with  sk-test-  | Live key starts with  sk-live-
CHAPA_SECRET_KEY=sk-test-xxxxxxxx (from dashboard.chapa.co → Settings → API Keys)

# Webhook secret (set in Chapa Dashboard → Webhooks, optional but recommended)
CHAPA_WEBHOOK_SECRET=your_chapa_webhook_secret_here

# ── Exchange rate (USD → ETB) ─────────────────────────────────────────────────
# Chapa requires ETB. Set this or use a live FX API in utils/exchangeRate.js
ETB_PER_USD=130

# ── Cloudinary (product images) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email ────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=BEKI Shop <your_email@gmail.com>
